# Webhook Configuration

# Legacy single webhook secret (backward compatible)
# WEBHOOK_SECRET=your-secret-key

# Multiple webhook providers (recommended)
# Format: JSON array of provider configurations
WEBHOOK_PROVIDERS='[
  {
    "name": "data-processing",
    "algorithm": "hmac-sha256",
    "secret": "data-processing-secret-key",
    "enabled": true
  },
  {
    "name": "external-partner",
    "algorithm": "rsa-sha256",
    "publicKey": "LS0tLS1CRUdJTiBQVUJMSUMgS0VZLS0tLS0...",
    "enabled": true,
    "timestampToleranceMs": 300000
  }
]'

# Notification Configuration

# Default notification channels
NOTIFICATION_DEFAULT_CHANNELS=in_app

# Maximum notifications per user per day (0 = unlimited)
NOTIFICATION_DEFAULT_DAILY_LIMIT=100

# Enable email notifications (requires email service setup)
NOTIFICATION_EMAIL_ENABLED=false
# EMAIL_SERVICE_PROVIDER=sendgrid
# SENDGRID_API_KEY=your-sendgrid-key
# EMAIL_FROM=noreply@lumenpulse.com

# Enable push notifications (requires FCM/APNs setup)
NOTIFICATION_PUSH_ENABLED=false
# FIREBASE_PROJECT_ID=your-firebase-project
# FIREBASE_PRIVATE_KEY=your-firebase-private-key
# FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# Enable SMS notifications (requires Twilio setup)
NOTIFICATION_SMS_ENABLED=false
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# Webhook delivery settings
NOTIFICATION_WEBHOOK_ENABLED=false
NOTIFICATION_WEBHOOK_TIMEOUT_MS=5000
NOTIFICATION_WEBHOOK_MAX_RETRIES=3

# Delivery retry settings
NOTIFICATION_DELIVERY_RETRY_MAX=3
NOTIFICATION_DELIVERY_RETRY_DELAY_MS=5000

# Quiet hours default (can be overridden per user)
NOTIFICATION_QUIET_HOURS_START=22
NOTIFICATION_QUIET_HOURS_END=7
NOTIFICATION_QUIET_HOURS_ALLOW_CRITICAL=true
