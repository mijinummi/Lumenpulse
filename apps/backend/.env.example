DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=lumenpulse_user
DB_PASSWORD=yourpassword
DB_DATABASE=lumenpulse_db
PYTHON_API_URL=http://localhost:8000
# Backend Configuration

# Database (matches docker-compose postgres service)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=lumenpulse
DB_PASSWORD=lumenpulse
DB_DATABASE=lumenpulse  

# Server
PORT=3000

# CORS – frontend URL(s) allowed to call the API.
# In production, this MUST be set. Restrict to your frontend origin(s).
# Comma-separated for multiple origins, e.g. https://app.example.com,https://www.example.com
# Development defaults to http://localhost:3000 and http://localhost:3001 if unset.
CORS_ORIGIN=http://localhost:3000

# Optional: set to "production" in production. Required for strict CORS (CORS_ORIGIN must be set).
# NODE_ENV=development

# News Provider API (CoinDesk)
# documentation is https://developers.coindesk.com/documentation/data-api/news_v1_search
COINDESK_API_KEY=your_api_key_here

# Redis Cache (matches docker-compose redis service)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
# Default cache TTL in milliseconds (300000 = 5 minutes)
CACHE_TTL_MS=300000

# Rate limiting
# Defaults change by NODE_ENV and can be overridden here.
RATE_LIMIT_TRACK_BY_IP=true
RATE_LIMIT_TRACK_BY_API_KEY=false
RATE_LIMIT_API_KEY_HEADER=x-api-key
RATE_LIMIT_REDIS_URL=redis://localhost:6379
RATE_LIMIT_REDIS_NAMESPACE=rate-limit
RATE_LIMIT_GLOBAL_LIMIT=120
RATE_LIMIT_GLOBAL_TTL_MS=60000
RATE_LIMIT_GLOBAL_BLOCK_MS=60000
RATE_LIMIT_AUTH_LIMIT=8
RATE_LIMIT_AUTH_TTL_MS=60000
RATE_LIMIT_AUTH_BLOCK_MS=300000
RATE_LIMIT_PORTFOLIO_READ_LIMIT=90
RATE_LIMIT_PORTFOLIO_READ_TTL_MS=60000
RATE_LIMIT_PORTFOLIO_READ_BLOCK_MS=60000
RATE_LIMIT_PORTFOLIO_WRITE_LIMIT=10
RATE_LIMIT_PORTFOLIO_WRITE_TTL_MS=60000
RATE_LIMIT_PORTFOLIO_WRITE_BLOCK_MS=120000

# Webhook — shared secret for HMAC-SHA256 signature verification
# Must match WEBHOOK_SECRET set in the data-processing service
WEBHOOK_SECRET=your_webhook_secret_here

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
